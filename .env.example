# Backend API base URL (Cloudflare Workers). Absolute, no trailing slash.
# Endpoints live under /api/... . This value is PUBLIC (baked into the bundle).
#
# Default committed in .env. Override locally via .env.local (gitignored).
# On Cloudflare Pages you may also set VITE_API_URL in the project build env vars.
VITE_API_URL=https://heartguardians-api.a20180424.workers.dev
