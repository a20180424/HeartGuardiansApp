# Backend API base URL (Cloudflare Workers). Absolute, no trailing slash.
# This value is PUBLIC — it is baked into the client bundle at build time.
#
# - Local dev:   set in .env.development (wrangler dev default below)
# - Web (Pages): set VITE_API_URL in the Cloudflare Pages project's build env vars
# - APK build:   set in .env.production.local (gitignored) before `npm run build`
VITE_API_URL=https://api.heartguardians.example
